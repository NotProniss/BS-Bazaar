# Environment files
.env
.env.*
bazaar-client/.env
bazaar-client/.env.*
bazaar-server/.env
bazaar-server/.env.*
!bazaar-client/.env.example
!bazaar-server/.env.example

# Environment switching script (contains sensitive config paths)
switch-env.ps1

# Node modules
node_modules/
bazaar-client/node_modules/
bazaar-server/node_modules/
**/node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Build output
dist/
build/
out/
bazaar-client/build/

# Docker-related
.dockerignore
docker-compose.override.yml

# Python cache (for scraping scripts)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
pip-log.txt
pip-delete-this-directory.txt

# Database files (keep structure, ignore data)
marketplace.db
sessions.db
*.sqlite
*.sqlite3
*.db
bazaar-server/marketplace.db
bazaar-server/sessions.db

# Package lock files (keep package.json, ignore lock files)
package-lock.json
yarn.lock
**/package-lock.json
**/yarn.lock

# Temporary files
*.tmp
*.temp

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Deployment artifacts
*.zip
*.tar.gz

# Keep deployment scripts but ignore any generated deployment configs
!deploy.sh
!deploy.bat
deployment-config.json

# Security and sensitive files
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json

# Cache and temporary directories
.cache/
.temp/
tmp/

# Editor and IDE specific
.vscode/settings.json
.vscode/launch.json
.idea/workspace.xml
.idea/tasks.xml

# System files
*.lnk